<?xml version="1.0"?>
<ruleset name="NU Research WordPress Standards">
    <description>PHPCS config for the NU Research WordPress theme and custom plugins.</description>

    <!-- Files and directories to scan -->
    <file>wp-content/themes/nu-research</file>
    <file>wp-content/plugins/fellows-deadline</file>
    <file>wp-content/plugins/swe-fellows-application</file>
    <file>wp-content/plugins/swe-mail-list</file>

    <!-- Exclude generated/vendor files -->
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/assets/js/*.min.js</exclude-pattern>
    <exclude-pattern>*/assets/css/*.min.css</exclude-pattern>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- Allow short array syntax [] instead of array() -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
    </rule>

    <!-- Require proper text domain for the theme -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array" value="nu-research,fellows-deadline,swe-fellows-application,swe-mail-list"/>
        </properties>
    </rule>

    <!-- PHP version compatibility -->
    <config name="testVersion" value="8.0-"/>

    <!-- Show progress and use colors in local runs -->
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- Show sniff codes in all reports -->
    <arg value="s"/>
</ruleset>
