{"request":{"hurl":"http:\/\/localhost:10005\/wp-content\/plugins\/fellows-deadline\/assets\/deadline.css","inline":"","enable_minification":true,"type":"css","handle":"fellows-deadline","version":"1.0.0"},"log":{"url":"\/wp-content\/plugins\/fellows-deadline\/assets\/deadline.css","success":true},"code":".fellows-countdown{display:inline-flex;align-items:center;gap:.5rem;font-size:.9rem;font-weight:600;padding:.45em .9em;border-radius:3px;line-height:1.4}.fellows-countdown--open{background:#f0faf4;color:#0f5132;border:1px solid #badbcc}.fellows-countdown--soon{background:#fff8e6;color:#664d03;border:1px solid #ffe69c}.fellows-countdown--closed{background:#f8f9fa;color:#495057;border:1px solid #dee2e6}.fellows-countdown__indicator{display:inline-block;width:.55em;height:.55em;border-radius:50%;background:#0f5132;flex-shrink:0}.utility-bar__row{display:flex;align-items:center;justify-content:space-between}.utility-bar .fellows-util-status,.utility-bar .fellows-util-status:visited{display:inline-flex;align-items:center;gap:.4em;font-size:.8125rem;font-weight:600;letter-spacing:.04em;text-decoration:none;color:rgb(255 255 255 \/ .65);transition:color .15s}.utility-bar .fellows-util-status:hover,.utility-bar .fellows-util-status:focus{color:#fff;outline-color:rgb(255 255 255 \/ .5)}.utility-bar .fellows-util-status--open,.utility-bar .fellows-util-status--open:visited{color:#6ee7a0}.utility-bar .fellows-util-status--open:hover{color:#9bf5bf}.utility-bar .fellows-util-status--soon,.utility-bar .fellows-util-status--soon:visited{color:#fcd34d}.utility-bar .fellows-util-status--soon:hover{color:#fde68a}.fellows-util-status--closed{display:inline-flex;align-items:center;gap:.4em;font-size:.8125rem;font-weight:600;letter-spacing:.04em;color:rgb(255 255 255 \/ .4)}.fellows-util-status__dot{display:inline-block;width:.45em;height:.45em;border-radius:50%;background:currentColor;flex-shrink:0;animation:fellows-pulse 2s ease-in-out infinite}@keyframes fellows-pulse{0%,100%{opacity:1}50%{opacity:.35}}.fellows-dl-banner{position:fixed;bottom:0;left:0;right:0;z-index:200;background:#142d4c;color:#fff;box-shadow:0 -2px 8px rgb(0 0 0 \/ .25)}.fellows-dl-banner__inner{display:flex;align-items:center;justify-content:space-between;padding-top:.75rem;padding-bottom:.75rem;gap:1rem}.fellows-dl-banner__msg{margin:0;font-size:.9rem;display:flex;align-items:center;gap:.75rem;flex-wrap:wrap}.fellows-dl-banner__msg a{color:#fff;text-decoration:underline;white-space:nowrap}.fellows-dl-banner__msg a:hover{opacity:.85}.fellows-dl-banner__dismiss{background:none;border:1px solid rgb(255 255 255 \/ .4);color:#fff;cursor:pointer;border-radius:2px;padding:.2em .5em;font-size:1rem;line-height:1;flex-shrink:0;transition:background .15s}.fellows-dl-banner__dismiss:hover{background:rgb(255 255 255 \/ .15)}.wp-admin .fellows-dl-snapshot td,.wp-admin .fellows-dl-snapshot th{padding:5px 10px}.wp-admin .fellows-dl-snapshot th{font-weight:400;text-align:left}.wp-admin .fellows-dl-snapshot__total th,.wp-admin .fellows-dl-snapshot__total td{font-weight:700;border-top:1px solid #dcdcde;padding-top:7px}.wp-admin .fellows-dl-snapshot__dates{margin-top:10px;font-size:.85rem;color:#646970}","status":true}