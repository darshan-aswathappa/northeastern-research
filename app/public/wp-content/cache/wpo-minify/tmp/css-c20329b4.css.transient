{"request":{"hurl":"http:\/\/northeastern-research.local\/wp-content\/plugins\/swe-fellows-application\/assets\/style.css","inline":"","enable_minification":true,"type":"css","handle":"swe-app-style","version":"2.0.0"},"log":{"url":"\/wp-content\/plugins\/swe-fellows-application\/assets\/style.css","success":true},"code":".swe-app{max-width:640px}.swe-app-hp{position:absolute!important;left:-9999px!important;width:1px;height:1px;overflow:hidden}.swe-app-live,.swe-app .screen-reader-text{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip-path:inset(50%);white-space:nowrap;border:0}.swe-app-progress{list-style:none;display:flex;gap:8px;margin:0 0 24px;padding:0;counter-reset:swe-steps}.swe-app-progress li{flex:1;counter-increment:swe-steps;font-size:.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:var(--color-text-muted,#595959);padding-top:10px;border-top:6px solid var(--gray-200,#e2e2e2)}.swe-app-progress li::before{content:counter(swe-steps) \". \"}.swe-app-progress li.is-active,.swe-app-progress li.is-complete{border-top-color:var(--nu-red,#c8102e);color:var(--color-text,#121212)}.swe-app-errors{border:2px solid var(--nu-red,#c8102e);background:#fdf2f4;padding:12px 16px;margin-bottom:20px}.swe-app-errors p{margin:0;font-weight:700;color:var(--nu-red-dark,#9c0c23)}.swe-app [hidden]{display:none!important}.swe-app-step{border:1px solid var(--color-border,#e2e2e2);background:var(--nu-white,#fff);padding:24px;margin:0 0 20px;display:flex;flex-direction:column;gap:18px}.swe-app-step legend{font-weight:700;font-size:1.125rem;padding:0 8px}.swe-app-step legend:focus{outline:3px solid var(--nu-red,#c8102e);outline-offset:2px}.swe-app-step-count{display:block;font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted,#595959)}.swe-app-field{display:flex;flex-direction:column;gap:6px;margin:0}.swe-app-field label{font-weight:700;font-size:.95rem}.swe-app-req{color:var(--nu-red,#c8102e)}.swe-app-field input,.swe-app-field select,.swe-app-field textarea{font:inherit;padding:10px 12px;border:1px solid var(--gray-800,#333);border-radius:2px;background:#fff;color:inherit;width:100%}.swe-app-hint{font-size:.875rem;color:var(--color-text-muted,#595959)}.swe-app-nav{display:flex;justify-content:space-between;gap:12px;margin:4px 0 0}.swe-app-nav .swe-app-next:only-child,.swe-app-nav .swe-app-submit:only-child{margin-left:auto}.swe-app-btn{display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:10px 28px;border-radius:999px;font:inherit;font-size:.9375rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;background:var(--nu-black,#000);color:var(--nu-white,#fff);border:none;cursor:pointer;transition:opacity 120ms ease}.swe-app-btn:hover{opacity:.85}.swe-app-btn:disabled{opacity:.6;cursor:wait}.swe-app-btn-secondary{background:none;color:var(--color-text,#121212);border:1px solid var(--nu-black,#000)}.swe-app-success{border:1px solid var(--color-border,#e2e2e2);background:var(--nu-white,#fff);padding:40px;text-align:center}.swe-app-success:focus{outline:3px solid var(--nu-red,#c8102e);outline-offset:2px}.swe-app-success h3{margin:0 0 12px}.swe-app-success p{margin:0;color:var(--color-text-secondary,#4a4a4a)}.swe-app-status-pill{display:inline-block;padding:2px 10px;border-radius:999px;font-size:12px;font-weight:600;background:#e2e2e2}.swe-app-status-new{background:#fce8ec;color:#9c0c23}.swe-app-status-reviewed{background:#fff3cd;color:#664d03}.swe-app-status-accepted{background:#d1e7dd;color:#0f5132}.swe-app-status-rejected{background:#e2e3e5;color:#41464b}","status":true}