{"request":{"hurl":"https:\/\/northeastern-research.local\/wp-content\/themes\/nu-research\/assets\/js\/nav.js","inline":"","enable_minification":true,"type":"js","handle":"nu-research-nav","version":"1783150645"},"log":{"url":"\/wp-content\/themes\/nu-research\/assets\/js\/nav.js","success":true},"code":"(function(){'use strict';var toggle=document.querySelector('.nav-toggle');var nav=document.getElementById('primary-nav');var mq=window.matchMedia('(min-width: 768px)');if(!toggle||!nav){return}\ndocument.documentElement.classList.add('nav-ready');function setOpen(open){toggle.setAttribute('aria-expanded',open?'true':'false');nav.setAttribute('data-collapsed',open?'false':'true')}\nsetOpen(mq.matches);toggle.addEventListener('click',function(){setOpen(toggle.getAttribute('aria-expanded')!=='true')});nav.addEventListener('keydown',function(e){if('Escape'===e.key&&!mq.matches){setOpen(!1);toggle.focus()}});mq.addEventListener('change',function(e){setOpen(e.matches)})})();window.addEventListener('load',function(){if(typeof AOS!=='undefined'){AOS.init({duration:600,once:!0,offset:80,})}});\n","status":true}