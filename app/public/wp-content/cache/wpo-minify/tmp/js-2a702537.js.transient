{"request":{"hurl":"https:\/\/northeastern-research.local\/wp-content\/themes\/nu-research\/assets\/js\/nav.js","inline":"","enable_minification":true,"type":"js","handle":"nu-research-nav","version":"1783408226"},"log":{"url":"\/wp-content\/themes\/nu-research\/assets\/js\/nav.js","success":true},"code":"(function(){'use strict';var toggle=document.querySelector('.nav-toggle');var nav=document.getElementById('primary-nav');var mq=window.matchMedia('(min-width: 1050px)');if(!toggle||!nav){return}\ndocument.documentElement.classList.add('nav-ready');function setOpen(open){toggle.setAttribute('aria-expanded',open?'true':'false');nav.setAttribute('data-collapsed',open?'false':'true');document.body.classList.toggle('nav-open',open&&!mq.matches)}\nsetOpen(mq.matches);toggle.addEventListener('click',function(){setOpen(toggle.getAttribute('aria-expanded')!=='true')});var subToggles=Array.prototype.slice.call(nav.querySelectorAll('.submenu-toggle'));function submenuFor(btn){return document.getElementById(btn.getAttribute('aria-controls'))}\nfunction setSubmenu(btn,open){btn.setAttribute('aria-expanded',open?'true':'false');var panel=submenuFor(btn);if(panel){panel.setAttribute('data-open',open?'true':'false')}}\nfunction closeAllSubmenus(except){subToggles.forEach(function(btn){if(btn!==except){setSubmenu(btn,!1)}})}\nsubToggles.forEach(function(btn){btn.removeAttribute('hidden');setSubmenu(btn,!1);btn.addEventListener('click',function(){var open=btn.getAttribute('aria-expanded')!=='true';closeAllSubmenus(btn);setSubmenu(btn,open)})});nav.addEventListener('keydown',function(e){if('Escape'!==e.key){return}\nvar openBtn=null;subToggles.forEach(function(btn){var panel=submenuFor(btn);if('true'===btn.getAttribute('aria-expanded')&&(btn===e.target||(panel&&panel.contains(e.target)))){openBtn=btn}});if(openBtn){setSubmenu(openBtn,!1);openBtn.focus();return}\nif(!mq.matches){setOpen(!1);toggle.focus()}});document.addEventListener('click',function(e){if(!nav.contains(e.target)){closeAllSubmenus(null)}});document.addEventListener('focusin',function(e){if(!nav.contains(e.target)){closeAllSubmenus(null)}});mq.addEventListener('change',function(e){setOpen(e.matches);closeAllSubmenus(null)})})();window.addEventListener('load',function(){if(typeof AOS!=='undefined'){AOS.init({duration:600,once:!0,offset:80,})}});\n","status":true}